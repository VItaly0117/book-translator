\@writefile{toc}{\contentsline {section}{Лекція 11. РЯДИ І ПЕРЕТВОРЕННЯ ФУР'Є МЕТА ЛЕКЦІЇ: Ввести поняття ряду Фур'є і показати, як періодичну функцію \texttt  {f(x)} можна подати рядом за синусами і косинусами. Якщо ж функція \texttt  {f(x)} є неперіодичною і визначена на всій дійсній осі, то ряд Фур'є природно переходить у перетворення Фур'є.}{57}{section*.72}\protected@file@percent }
\newlabel{ux43bux435ux43aux446ux456ux44f-11.-ux440ux44fux434ux438-ux456-ux43fux435ux440ux435ux442ux432ux43eux440ux435ux43dux43dux44f-ux444ux443ux440ux454-ux43cux435ux442ux430-ux43bux435ux43aux446ux456ux457-ux432ux432ux435ux441ux442ux438-ux43fux43eux43dux44fux442ux442ux44f-ux440ux44fux434ux443-ux444ux443ux440ux454-ux456-ux43fux43eux43aux430ux437ux430ux442ux438-ux44fux43a-ux43fux435ux440ux456ux43eux434ux438ux447ux43dux443-ux444ux443ux43dux43aux446ux456ux44e-fx-ux43cux43eux436ux43dux430-ux43fux43eux434ux430ux442ux438-ux440ux44fux434ux43eux43c-ux437ux430-ux441ux438ux43dux443ux441ux430ux43cux438-ux456-ux43aux43eux441ux438ux43dux443ux441ux430ux43cux438.-ux44fux43aux449ux43e-ux436-ux444ux443ux43dux43aux446ux456ux44f-fx-ux454-ux43dux435ux43fux435ux440ux456ux43eux434ux438ux447ux43dux43eux44e-ux456-ux432ux438ux437ux43dux430ux447ux435ux43dux430-ux43dux430-ux432ux441ux456ux439-ux434ux456ux439ux441ux43dux456ux439-ux43eux441ux456-ux442ux43e-ux440ux44fux434-ux444ux443ux440ux454-ux43fux440ux438ux440ux43eux434ux43dux43e-ux43fux435ux440ux435ux445ux43eux434ux438ux442ux44c-ux443-ux43fux435ux440ux435ux442ux432ux43eux440ux435ux43dux43dux44f-ux444ux443ux440ux454.}{{}{57}{\texorpdfstring {Лекція 11. РЯДИ І ПЕРЕТВОРЕННЯ ФУР'Є МЕТА ЛЕКЦІЇ: Ввести поняття ряду Фур'є і показати, як періодичну функцію \texttt {f(x)} можна подати рядом за синусами і косинусами. Якщо ж функція \texttt {f(x)} є неперіодичною і визначена на всій дійсній осі, то ряд Фур'є природно переходить у перетворення Фур'є.}{Лекція 11. РЯДИ І ПЕРЕТВОРЕННЯ ФУР'Є МЕТА ЛЕКЦІЇ: Ввести поняття ряду Фур'є і показати, як періодичну функцію f(x) можна подати рядом за синусами і косинусами. Якщо ж функція f(x) є неперіодичною і визначена на всій дійсній осі, то ряд Фур'є природно переходить у перетворення Фур'є.}}{section*.72}{}}
\@writefile{toc}{\contentsline {section}{Преобразование Фурье Як уже зазначалося раніше, неперіодичні функції, задані на \texttt  {(-\textbackslash {}infty,+\textbackslash {}infty)}, не розкладаються у звичайні ряди Фур'є. Проте для деяких таких функцій можна побудувати аналог ряду Фур'є у вигляді інтеграла Фур'є, тобто розкладу за неперервним спектром частот:}{59}{section*.73}\protected@file@percent }
\newlabel{ux43fux440ux435ux43eux431ux440ux430ux437ux43eux432ux430ux43dux438ux435-ux444ux443ux440ux44cux435-ux44fux43a-ux443ux436ux435-ux437ux430ux437ux43dux430ux447ux430ux43bux43eux441ux44f-ux440ux430ux43dux456ux448ux435-ux43dux435ux43fux435ux440ux456ux43eux434ux438ux447ux43dux456-ux444ux443ux43dux43aux446ux456ux457-ux437ux430ux434ux430ux43dux456-ux43dux430--inftyinfty-ux43dux435-ux440ux43eux437ux43aux43bux430ux434ux430ux44eux442ux44cux441ux44f-ux443-ux437ux432ux438ux447ux430ux439ux43dux456-ux440ux44fux434ux438-ux444ux443ux440ux454.-ux43fux440ux43eux442ux435-ux434ux43bux44f-ux434ux435ux44fux43aux438ux445-ux442ux430ux43aux438ux445-ux444ux443ux43dux43aux446ux456ux439-ux43cux43eux436ux43dux430-ux43fux43eux431ux443ux434ux443ux432ux430ux442ux438-ux430ux43dux430ux43bux43eux433-ux440ux44fux434ux443-ux444ux443ux440ux454-ux443-ux432ux438ux433ux43bux44fux434ux456-ux456ux43dux442ux435ux433ux440ux430ux43bux430-ux444ux443ux440ux454-ux442ux43eux431ux442ux43e-ux440ux43eux437ux43aux43bux430ux434ux443-ux437ux430-ux43dux435ux43fux435ux440ux435ux440ux432ux43dux438ux43c-ux441ux43fux435ux43aux442ux440ux43eux43c-ux447ux430ux441ux442ux43eux442}{{}{59}{\texorpdfstring {Преобразование Фурье Як уже зазначалося раніше, неперіодичні функції, задані на \texttt {(-\textbackslash {}infty,+\textbackslash {}infty)}, не розкладаються у звичайні ряди Фур'є. Проте для деяких таких функцій можна побудувати аналог ряду Фур'є у вигляді інтеграла Фур'є, тобто розкладу за неперервним спектром частот:}{Преобразование Фурье Як уже зазначалося раніше, неперіодичні функції, задані на (-\textbackslash infty,+\textbackslash infty), не розкладаються у звичайні ряди Фур'є. Проте для деяких таких функцій можна побудувати аналог ряду Фур'є у вигляді інтеграла Фур'є, тобто розкладу за неперервним спектром частот:}}{section*.73}{}}
