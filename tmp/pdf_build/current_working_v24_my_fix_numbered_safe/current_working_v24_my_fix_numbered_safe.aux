\@writefile{toc}{\contentsline {subsection}{МЕТА ЛЕКЦІЇ Проілюструвати основні властивості перетворення Фур'є та показати, як ці властивості застосовуються до розв'язання рівнянь з частинними похідними. Зокрема, ми побачимо, як під дією перетворення Фур'є операція диференціювання замінюється множенням, а диференціальні рівняння переходять в алгебраїчні.}{61}{section*.77}\protected@file@percent }
