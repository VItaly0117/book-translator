\@writefile{toc}{\contentsline {section}{ПОВАГА - 1. Аналіз розмірності особливо важливий у чисельних методах, оскільки більшість програм написані для розв'язання загальних математичних задач і не передбачають використання великої кількості фізичних параметрів. Ті, хто хоче користуватися цими програмами, повинні перетворити свою задачу у відповідну форму, розв'язати її на комп'ютері, а потім довести числові результати до потрібного розміру.}{7}{section*.6}\protected@file@percent }
