\@writefile{toc}{\contentsline {section}{ЗАУВАЖЕННЯ - 1. Общее решение уравнения с частными производными второго порядка содержит две произвольные функции, а общее решение обыкновенного дифференциального уравнения содержит две произвольные постоянные. Значит, у уравнения с частными производными больше решений, чем у обыкновенного дифференциального уравнения.}{15}{section*.7}\protected@file@percent }
