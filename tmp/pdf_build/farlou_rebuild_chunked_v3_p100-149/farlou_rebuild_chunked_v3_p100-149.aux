\@writefile{toc}{\contentsline {section}{ПРИМІТКИ1. Аналогічно можна класифікувати лінійні рівняння другого порядку з \emph  {трьох або більше змінних}, але для цього потрібен матричний аналіз. Наприклад, рівняння другого порядку з трьома змінними}{11}{section*.1}\protected@file@percent }
