\@writefile{toc}{\contentsline {subsection}{ПЕРЕТВОРЕННЯ СКЛАДНИХ РІВНЯНЬ У ПРОСТУ ФОРМУМЕТА ЛЕКЦІЇ Показати, як PPP для функції \(u(x, t)\) можна перетворити на простіший PPP для нової функції \(w(x, t)\). Вибір правильної трансформації зазвичай базується на ненавмисному намірі. У нашій лекції}{8}{section*.1}\protected@file@percent }
