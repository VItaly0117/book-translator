\newlabel{ux43cux435ux442ux43eux434-ux440ux438ux442ux446ux430-ux43cux438ux43dux438ux43cux438ux437ux430ux446ux438ux438-ux444ux443ux43dux43aux446ux438ux43eux43dux430ux43bux43eux432}{{}{124}{Метод Ритца минимизации функционалов}{section*.119}{}}
\@writefile{toc}{\contentsline {section}{\textbf  {ЗА}ДАЧИ}{126}{section*.120}\protected@file@percent }
\newlabel{ux437ux430ux434ux430ux447ux438-1}{{}{126}{\texorpdfstring {\textbf {ЗА}ДАЧИ}{ЗАДАЧИ}}{section*.120}{}}
\@writefile{toc}{\contentsline {section}{РЕШЕНИЕ УРАВНЕНИЙ С ЧАСТНЫМИ ПРОИЗВОДНЫМИ МЕТОДАМИ ТЕОРИИ ВОЗМУЩЕНИЙ МЕТА ЛЕКЦІЇ: Показать, как различные сложные задачи (нелинейные уравнения с переменными коэффициентами, области неправильной формы и т. д.) можно решить методом возмущения более простых задач. Иными словами, мы хотим показать, как следует изменить решение простой задачи, чтобы оно давало приближенное решение трудной задачи.}{129}{section*.121}\protected@file@percent }
